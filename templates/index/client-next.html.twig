{% extends 'base.html.twig' %}

{% block title %}Client Next Download{% endblock %}

{% block content %}
    <section class="section-client-next">
        <div class="header">
            <div class="content">
                <h1><span>Client 3.0</span></h1>
                <p>The next generation of our desktop client is here!<br />Try it out now, available for Windows and Linux!</p>
            </div>

            <video autoplay muted loop src="{{ asset('assets/img/client3_header.webm') }}"></video>
        </div>

        <div class="trailer">
            <iframe src="https://www.youtube-nocookie.com/embed/gdoOuwE2xWE" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
        </div>

        <div class="downloads">
            <a href="" target="_blank" class="button download-windows">
                <div class="icon">
                    <i class="mdi mdi-microsoft-windows"></i>
                </div>
                <span class="name">Windows</span>
                <span class="version">v3.30.0</span>
            </a>
            <a href="" target="_blank" class="button download-linux">
                <div class="icon">
                    <i class="mdi mdi-linux"></i>
                </div>
                <span class="name">Linux</span>
                <span class="version">v3.30.0</span>
            </a>
            <a href="" target="_blank" class="button download-linux appimage">
                <div class="icon">
                    <i class="mdi mdi-linux"></i>
                </div>
                <span class="name">Linux (AppImage)</span>
                <span class="version">v3.30.0</span>
            </a>
            <a href="" target="_blank" class="button nightly download-windows">
                <div class="icon">
                    <i class="mdi mdi-microsoft-windows"></i>
                </div>
                <span class="name">Windows</span>
                <span class="version">Nightly Dev</span>
            </a>
            <a href="" target="_blank" class="button nightly download-linux">
                <div class="icon">
                    <i class="mdi mdi-linux"></i>
                </div>
                <span class="name">Linux</span>
                <span class="version">Nightly Dev</span>
            </a>
            <a href="" target="_blank" class="button nightly download-linux appimage">
                <div class="icon">
                    <i class="mdi mdi-linux"></i>
                </div>
                <span class="name">Linux (AppImage)</span>
                <span class="version">Nightly Dev</span>
            </a>
        </div>

        <div class="features">
            <div class="item">
                <h3>Rewritten from scratch</h3>
                <p>The new desktop client has been fully rewritten to be fancier, faster and cross-platform.</p>
            </div>
            <div class="item">
                <h3>Featured history</h3>
                <p>Missed a featured chart? The frontpage now features a history of previously featured charts.</p>
            </div>
            <div class="item">
                <h3>Login & review</h3>
                <p>You can now log into your account and review charts directly. Soon, you'll be able to manage your playlists and upload new charts as well.</p>
            </div>
            <div class="item">
                <h3>Playlists</h3>
                <p>Playlists can finally be viewed and added to the queue directly. No need to download each chart manually!</p>
            </div>
        </div>

        <div class="screenshots">
            <img src="{{ asset('assets/img/clientNextScreenshots/frontpage.png') }}" alt="Client Next Screenshot" />
            <img src="{{ asset('assets/img/clientNextScreenshots/search.png') }}" alt="Client Next Screenshot" />
            <img src="{{ asset('assets/img/clientNextScreenshots/chart.png') }}" alt="Client Next Screenshot" />
            <img src="{{ asset('assets/img/clientNextScreenshots/playlist.png') }}" alt="Client Next Screenshot" />
            <img src="{{ asset('assets/img/clientNextScreenshots/user.png') }}" alt="Client Next Screenshot" />
            <img src="{{ asset('assets/img/clientNextScreenshots/reviews.png') }}" alt="Client Next Screenshot" />
        </div>

        <dialog id="lightboxContainer">
            <img src="" alt="" />
        </dialog>

        {% if song %}
            <div class="chart">
                {{ include('components/song-item.html.twig', {song: song}) }}
            </div>
        {% endif %}

        <div class="footer" style="background: #000000">
            <i class="mdi mdi-open-source-initiative" style="font-size: 64px;"></i>
            <p style="opacity: 0.6; display: block; padding-bottom: 15px;">The SpinShare client is available<br />under the AGPL-3.0 license!</p>
            <a href="https://github.com/SpinShare/client-next" target="_blank" class="button">client-next on Github</a>
        </div>
    </section>
{% endblock %}

{% block scripts %}
    <script>
        let DOMLightboxEntries = document.querySelectorAll('.screenshots img');
        let DOMLightboxContainer = document.querySelector('#lightboxContainer');

        DOMLightboxContainer.addEventListener('click', () => {
            DOMLightboxContainer.close();
        });

        DOMLightboxEntries.forEach(entry => {
            entry.addEventListener('click', () => {
                DOMLightboxContainer.querySelector('img').src = entry.src;
                DOMLightboxContainer.showModal();
            })
        })
    </script>
    <script>
        (async () => {
            async function fetchJson(url) {
                const res = await fetch(url);
                return res.json();
            }

            function findAsset(release, platform) {
                const assets = release.assets || [];
                if (platform === "windows") return assets.find(a => a.name.includes(".exe"));
                if (platform === "linux") return assets.find(a => a.name.includes("linux-x64"));
                if (platform === "linux-appimage") return assets.find(a => a.name.includes("AppImage"));
                return null;
            }

            function versionFromName(name) {
                const m = /\(([^)]+)\)/.exec(name || "");
                return m ? m[1] : "";
            }

            function setDisabled(a) {
                a.style.opacity = "0.1";
                a.style.cursor = "not-allowed";
                a.href = "javascript:void(0);";
            }

            function setStableButton(selector, release, platform) {
                const a = document.querySelector(selector);
                if (!a) return;

                const asset = findAsset(release, platform);
                if (!asset || !asset.browser_download_url || asset.size <= 0) return setDisabled(a);

                a.href = asset.browser_download_url;

                const v = a.querySelector(".version");
                if (v) {
                    const mb = Math.round(asset.size / 1000000);
                    v.textContent = `Stable ${versionFromName(release.name)} (${mb} MB)`;
                }
            }

            function setNightlyButton(selector, release, platform) {
                const a = document.querySelector(selector);
                if (!a) return;

                const asset = findAsset(release, platform);
                if (!asset || !asset.browser_download_url || asset.size <= 0) return setDisabled(a);

                a.href = asset.browser_download_url;
            }

            try {
                const stable = await fetchJson("https://api.github.com/repos/SpinShare/client-next/releases/latest");
                const releases = await fetchJson("https://api.github.com/repos/SpinShare/client-next/releases");
                const nightly = releases.find(r => r.prerelease);

                // stable
                setStableButton(".download-windows:not(.nightly)", stable, "windows");
                setStableButton(".download-linux:not(.nightly):not(.appimage)", stable, "linux");
                setStableButton(".download-linux.appimage:not(.nightly)", stable, "linux-appimage");

                // nightly
                if (nightly) {
                    setNightlyButton(".download-windows.nightly", nightly, "windows");
                    setNightlyButton(".download-linux.nightly", nightly, "linux");
                    setNightlyButton(".download-linux.appimage.nightly", nightly, "linux-appimage");
                }
            } catch (e) {
                console.error(e);
                const downloads = document.querySelector(".downloads");
                if (downloads) downloads.style.display = "none";
            }
        })();
    </script>
{% endblock %}

{% block styles %}
    <link rel="stylesheet" href="{{ asset('assets/css/client-next.css?v=' ~ date().timestamp) }}" />
{% endblock %}
